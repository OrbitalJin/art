{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Art",
  "version": "0.1.1",
  "identifier": "com.horijin.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Art",
        "minWidth": 500,
        "minHeight": 600,
        "fullscreen": false,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/logo.png",
      "icons/logo.png",
      "icons/logo.png",
      "icons/logo.ico",
      "icons/logo.icns"
    ]
  }
}
